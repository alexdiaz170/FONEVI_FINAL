# ============================================================
#  FONEVI — .gitignore
#  Aplica para todo el repositorio (frontend + backend)
# ============================================================

# ── Secretos y credenciales (NUNCA subir) ────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.cert
*.p12
*.pfx
secrets/
credentials/

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
yarn.lock

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
*.log.*
combined.log
error.log
access.log

# ── Build y distribución ─────────────────────────────────────
dist/
build/
out/
.cache/
.parcel-cache/
.next/
.nuxt/
.output/

# ── Archivos temporales del sistema ──────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── IDEs y editores ───────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
jest.config.local.js

# ── Archivos de respaldo generados por el sistema ────────────
*.bak
*.backup
*.orig
*.tmp
*.temp
*~

# ── Exportaciones generadas ──────────────────────────────────
exports/
reportes/
downloads/
*.pdf
*.xlsx

# ── Subidas de usuarios ──────────────────────────────────────
uploads/
public/uploads/
storage/

# ── Base de datos local ───────────────────────────────────────
*.sqlite
*.sqlite3
*.db
dump.sql
backup_*.sql
restore_*.sql

# ── WhatsApp / certificados de integración ───────────────────
wa_credentials/
whatsapp-session/
.wwebjs_auth/
.wwebjs_cache/

# ── Railway / Render / Heroku ─────────────────────────────────
.railway/
.render/
Procfile.local

# ── Turborepo cache ──────────────────────────────────────────
.turbo/

# ── Misc ─────────────────────────────────────────────────────
.vercel
.netlify
*.zip
*.tar.gz
*.rar
.sass-cache/

# Frontend build servido por backend
packages/backend/public/
