{
  "name": "@fonevi/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:dev": "npx tsx watch src/index.ts",
    "start:full": "npm run build:frontend && npm run start:dev",
    "build:frontend": "cd ../frontend && npm run build && cd ../backend && node scripts/copy-frontend.js",
    "lint": "tsc --noEmit",
    "backup": "npx tsx src/infrastructure/backup/runBackup.ts",
    "restore": "npx tsx src/infrastructure/backup/runRestore.ts",
    "db:generate": "prisma generate --schema=../shared/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=../shared/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=../shared/prisma/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fonevi/external": "*",
    "@fonevi/shared": "*",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.6.0",
    "pdfkit": "^0.19.1",
    "prisma": "^5.22.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/xlsx": "^0.0.35",
    "supertest": "^7.2.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.3"
  }
}
