# ─────────────────────────────────────────────────────────────
# FONEVI Backend — Variables de entorno
# Copia este archivo a .env y completa los valores reales
# ¡NUNCA subas .env al repositorio!
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5432/fonevi_db"

# Seguridad JWT (mínimo 32 caracteres aleatorios)
JWT_SECRET="cambia-esto-por-una-clave-aleatoria-larga-min32chars"
JWT_EXPIRES_IN="8h"

# Bcrypt (número de rounds — 12 es seguro y razonablemente rápido)
BCRYPT_ROUNDS=12

# Puerto del servidor
PORT=3000
NODE_ENV=development

# WhatsApp Business API (opcional)
WA_TOKEN=""
WA_PHONE_ID=""
WA_VERIFY_TOKEN=""

# CORS — origen permitido del frontend (sin barra final)
CORS_ORIGIN="http://localhost:5500"
